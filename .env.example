# Runtime
NODE_ENV=production
PORT=3000
# Trust X-Forwarded-* when behind Nginx/Traefik
BEHIND_PROXY=true

# JSON body size cap (Express)
JSON_BODY_LIMIT=2mb

# Auth: in production (NODE_ENV=production), auth is required by default (REQUIRE_AUTH=true).
# Single-tenant: set AUTH_TOKEN and call POST /v1/send with Bearer token.
AUTH_TOKEN=

# Multi-tenant: JSON map appId -> secret token (Bearer must match entry for body.appId)
# Example: {"azersoft-nc":"long-random-secret","other":"another-secret"}
APP_TOKENS_JSON=

# Optional: restrict appId values when using AUTH_TOKEN-only mode (comma-separated)
# ALLOWED_APP_IDS=azersoft-nc,internal-tools

# CORS allowlist for browser callers (comma-separated origins). Leave empty in trusted server-to-server only setups.
ALLOWED_ORIGINS=https://azersoft.nc,https://www.azersoft.nc

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Rate limiting (per IP; optionally combined with appId on /v1/send)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
RATE_LIMIT_PER_APP=true

# Optional anti-abus: field name that must stay empty (bots often fill it)
# HONEYPOT_FIELD=company_website

# Optional: reject if |Date.now() - clientTs| exceeds this (ms); clientTs is optional on /v1/send
CLIENT_TS_MAX_SKEW_MS=300000

# Captcha hook (disabled by default). If true without provider integration, /v1/send returns 501.
CAPTCHA_ENABLED=false

# Logging
LOG_LEVEL=info
